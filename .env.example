# ── App ──────────────────────────────────────────────
APP_NAME=Enterprise Task Agent
ENVIRONMENT=development

# ── Tooling mode ─────────────────────────────────────
# Keep mock tools on for a deterministic, offline-safe demo.
USE_MOCK_TOOLS=true

# ── Planner / LLM ────────────────────────────────────
# LLM_PROVIDER: mock | openai | azure
LLM_PROVIDER=mock

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-06-01

# ── Microsoft Entra ID (Azure AD) sign-in ────────────
# Leave blank to run in offline dev mode (role dropdown, mock tools).
# Fill these in from your Azure App Registration to enable REAL Microsoft
# login + real Microsoft 365 actions. See docs/AUTH_SETUP.md.
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=http://localhost:8000/auth/callback
ENTRA_POST_LOGOUT_REDIRECT_URI=http://localhost:8000/

# App roles / groups that elevate a user above 'employee'
ROLE_CLAIM_ADMIN=TaskAgent.Admin
ROLE_CLAIM_MANAGER=TaskAgent.Manager

# ── Session ──────────────────────────────────────────
# MUST be a long random string in production.
SESSION_SECRET=dev-insecure-change-me
SESSION_HTTPS_ONLY=false

# ── Microsoft Graph ──────────────────────────────────
GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
DEFAULT_TIMEZONE=Asia/Kolkata

# ── Optional: official Accenture internal API (from IT) ──
ACCENTURE_API_BASE_URL=
ACCENTURE_API_SCOPE=

# ── Misc ─────────────────────────────────────────────
REQUEST_TIMEOUT_SECONDS=30
